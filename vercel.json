{
  "version": 2,
  "builds": [
    { "src": "api/ai.js", "use": "@vercel/node" },
    { "src": "api/candidates.js", "use": "@vercel/node" },
    { "src": "api/leads.js", "use": "@vercel/node" },
    { "src": "api/submit-candidate.js", "use": "@vercel/node" },
    { "src": "api/apify-search.js", "use": "@vercel/node" },
    { "src": "api/apify-start.js", "use": "@vercel/node" },
    { "src": "api/apify-poll.js", "use": "@vercel/node" },
    { "src": "api/apify-enrich.js", "use": "@vercel/node" },
    { "src": "api/save-candidates.js", "use": "@vercel/node" },
    { "src": "api/parse-brief.js", "use": "@vercel/node" },
    { "src": "api/crm.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ai", "dest": "/api/ai.js" },
    { "src": "/api/candidates", "dest": "/api/candidates.js" },
    { "src": "/api/leads", "dest": "/api/leads.js" },
    { "src": "/api/submit-candidate", "dest": "/api/submit-candidate.js" },
    { "src": "/api/apify-search", "dest": "/api/apify-search.js" },
    { "src": "/api/apify-start", "dest": "/api/apify-start.js" },
    { "src": "/api/apify-poll", "dest": "/api/apify-poll.js" },
    { "src": "/api/apify-enrich", "dest": "/api/apify-enrich.js" },
    { "src": "/api/save-candidates", "dest": "/api/save-candidates.js" },
    { "src": "/api/parse-brief", "dest": "/api/parse-brief.js" },
    { "src": "/api/crm", "dest": "/api/crm.js" },
    { "src": "/demo", "dest": "/demo.html" },
    { "src": "/demo.html", "dest": "/demo.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/client", "dest": "/client.html" },
    { "src": "/client.html", "dest": "/client.html" },
    { "src": "/join", "dest": "/join.html" },
    { "src": "/join.html", "dest": "/join.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
